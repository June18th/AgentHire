# ============================================
# JobClaw 环境变量配置示例
# ============================================
# 复制此文件为 .env 并填写实际的值
# 注意: 不要将 .env 文件提交到版本控制系统
# ============================================

# ============================================
# JWT 配置
# ============================================
JOBCLAW_JWT_ISSUER=jobclaw
# 开发环境可留空使用本地 fallback；生产环境必须使用至少 32 位强随机值
JOBCLAW_JWT_SECRET=
JOBCLAW_JOB_CLAW_JWT_EXPIRE=2592000

# ============================================
# 站点配置
# ============================================
JOBCLAW_SITE_LOGIN_QR_IMG=https://cdn.tobebetterjavaer.com/paicoding/paicoding-qrcode.png
JOBCLAW_SITE_WEBSITE_NAME=求职派
JOBCLAW_SITE_WEBSITE_LOGO=https://oc.paicoding.com/favicon.icon
JOBCLAW_SITE_WEBSITE_HOST=http://localhost
JOBCLAW_SITE_WEB_SITE_URL=http://localhost:8088
JOBCLAW_SITE_AUTO_OPEN=true

# ============================================
# 图片存储配置
# ============================================
JOBCLAW_IMG_ABS_TMP_PATH=./workspace/storage/
JOBCLAW_IMG_WEB_IMG_PATH=/oc/img/
JOBCLAW_IMG_CDN_HOST=http://localhost:8087
JOBCLAW_IMG_STORAGE_TYPE=local
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=jobclaw
MINIO_BUCKET_PUBLIC_IMAGE=jobclaw-public
MINIO_BUCKET_PRIVATE_MATERIAL=jobclaw-private
MINIO_BUCKET_TEMP=jobclaw-temp
MINIO_BUCKET_EXPORT=jobclaw-export

# ============================================
# 数据库配置
# ============================================
JOBCLAW_DATABASE_NAME=jobclaw
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USERNAME=sa
DATABASE_PASSWORD=

# ============================================
# Redis 配置
# ============================================
JOBCLAW_REDIS_ENABLED=false
JOBCLAW_REDIS_KEY_PREFIX=jobclaw
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=jobclaw_redis
REDIS_DATABASE=0
REDIS_TIMEOUT=3s

# ============================================
# 消息队列配置
# ============================================
JOBCLAW_MQ_ENABLED=false
JOBCLAW_MQ_PROVIDER=kafka
JOBCLAW_MQ_TOPIC_DOMAIN_EVENT=jobclaw.domain-event
JOBCLAW_MQ_TOPIC_LLM_AUDIT=jobclaw.llm-audit
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Host port for Kafka TCP clients. Do not open it with http://localhost:9092/.
KAFKA_PORT=9092
KAFKA_CONSUMER_GROUP_ID=jobclaw
KAFKA_PRODUCER_RETRIES=3

# ============================================
# Elasticsearch search config
# ============================================
JOBCLAW_SEARCH_ES_ENABLED=false
ELASTICSEARCH_ENDPOINT=http://localhost:9200
ELASTICSEARCH_PORT=9200
JOBCLAW_SEARCH_ES_INDEX=jobclaw_oc_job
JOBCLAW_SEARCH_ES_CONNECT_TIMEOUT_MS=2000
JOBCLAW_SEARCH_ES_SOCKET_TIMEOUT_MS=5000

# ============================================
# Agent 配置
# ============================================
AGENT_WORKSPACE=file:./workspace/

# --- Agent 上下文窗口配置 ---
AGENT_CONTEXT_WINDOW_ENABLED=false
AGENT_CONTEXT_SUMMARY=false
AGENT_CONTEXT_SUMMARY_UPDATE_FREQUENCY=10
AGENT_CONTEXT_IDENTITY_AUTO_UPDATE=false
AGENT_CONTEXT_MAX_MESSAGES=20
AGENT_CONTEXT_KEEP_RECENT=10
AGENT_CONTEXT_MAX_TOKENS=8000
AGENT_CONTEXT_FILTER_SHORT=true
AGENT_CONTEXT_SHORT_THRESHOLD=5
AGENT_CONTEXT_UPDATE_identity_FREQUENCY=10

# --- Agent 渠道配置 - 微信 ClawBot ---
AGENT_CHANNEL_WECHAT_CLAWBOT_ENABLED=true

# --- Agent 渠道配置 - 钉钉 ---
AGENT_CHANNEL_DINGDING_ENABLED=true

# --- Agent 渠道配置 - 飞书 ---
AGENT_CHANNEL_FEISHU_ENABLED=true

# --- Agent 工具配置 - Playwright ---
AGENT_TOOL_PLAYWRIGHT_ENABLED=false
AGENT_PLAYWRIGHT_HEADLESS=true
AGENT_TOOL_PLAN_NOTEBOOK_ENABLED=true
AGENT_TOOL_AUDIT_ENABLED=true

# --- Agent 工具配置 - 动态发现 ---
AGENT_TOOL_DYNAMIC_DISCOVERY_ENABLED=true
AGENT_TOOL_DYNAMIC_DISCOVERY_MAX_RESULTS=10
AGENT_TOOL_DYNAMIC_DISCOVERY_LUCENE_MIN_SCORE_THRESHOLD=0.25

# --- Agent MCP 客户端配置 ---
# macOS 用户请改为 classpath:mcp-servers-mac.json
AGENT_MCP_CLIENT_ENABLED=false
MCP_SERVERS_CONFIG=classpath:mcp-servers.json

# --- Agent AI 偏好配置 ---
AGENT_AI_COLLECTOR=AI_BASED

# --- Agent 任务调度配置 (JobRunr) ---
AGENT_JOB_BACKGROUND_JOB_SERVER_ENABLED=true
AGENT_JOB_WORKER_COUNT=1
AGENT_JOB_DASHBOARD_ENABLED=true
AGENT_JOB_DASHBOARD_PORT=8099

# ============================================
# 微信登录配置
# ============================================
WX_LOGIN_QR_TYPE=SUBSCRIPTION_ACCOUNT
WX_LOGIN_APP_ID=
WX_LOGIN_APP_SECRET=
WX_LOGIN_QR_IMG=
WX_LOGIN_QR_LOGO=
WX_SECURITY_CHECK_TOKEN=
WX_LOGIN_SUBSCRIBE_WELCOME_INFO=欢迎来到求职派，请关注公众号，获取更多信息

# ============================================
# 微信支付配置
# ============================================
WX_PAY_ENABLE=false
WX_PAY_APP_ID=ww1****3e3
WX_PAY_MERCHANT_ID=162****72
WX_PAY_PRIVATE_KEY=cert/apiclient_key.pem
WX_PAY_MERCHANT_SERIAL_NUMBER=228065B**********F17C37A
WX_PAY_API_V3_KEY=Pai******1
WX_PAY_NOTIFY_URL=https://job.paicoding.cn/api/wx/payNotify
WX_PAY_REFUND_NOTIFY_URL=https://job.paicoding.cn/api/wx/refundNotify

# ============================================
# 其他配置
# ============================================
JOBCLAW_MAIN_MODEL=zhipu

# ============================================
# 服务器配置
# ============================================
JOBCLAW_SERVER_PORT=8087
JOBCLAW_SERVER_COMPRESSION_ENABLED=true
JOBCLAW_SERVER_COMPRESSION_MIN_RESPONSE_SIZE=2KB
