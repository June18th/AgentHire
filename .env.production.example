# Copy this file to .env.production before production deployment.
# Do not commit .env.production.

# Public entry. Use a real domain for online traffic.
JOBCLAW_SITE_WEB_SITE_URL=https://job.example.com
JOBCLAW_PUBLIC_PORT=80

# Docker Compose profiles for optional infrastructure.
# Enable only the components you need; API degrades when a component is off or unreachable.
# Full stack: redis,kafka,elasticsearch,minio
COMPOSE_PROFILES=

# Strong secrets are required in production.
MYSQL_DATABASE=jobclaw
MYSQL_ROOT_PASSWORD=CHANGE_ME_mysql_root_password
REDIS_PASSWORD=CHANGE_ME_redis_password
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key_at_least_16_chars
JOBCLAW_JWT_ISSUER=jobclaw
JOBCLAW_JWT_SECRET=CHANGE_ME_jwt_secret_at_least_32_chars
JOBCLAW_JOB_CLAW_JWT_EXPIRE=2592000

# Runtime baseline.
JOBCLAW_REDIS_KEY_PREFIX=jobclaw
JOBCLAW_MQ_PROVIDER=kafka
JOBCLAW_MQ_TOPIC_DOMAIN_EVENT=jobclaw.domain-event
JOBCLAW_MQ_TOPIC_LLM_AUDIT=jobclaw.llm-audit
KAFKA_CONSUMER_GROUP_ID=jobclaw-prod
KAFKA_PRODUCER_RETRIES=3
KAFKA_NUM_PARTITIONS=3
# Component toggles (match COMPOSE_PROFILES; API degrades gracefully when disabled or unreachable)
JOBCLAW_REDIS_ENABLED=false
JOBCLAW_MQ_ENABLED=false
JOBCLAW_SEARCH_ES_ENABLED=false
ELASTICSEARCH_ENDPOINT=http://elasticsearch:9200
JOBCLAW_IMG_STORAGE_TYPE=local
JOBCLAW_SEARCH_ES_INDEX=jobclaw_oc_job
JOBCLAW_SEARCH_ES_CONNECT_TIMEOUT_MS=2000
JOBCLAW_SEARCH_ES_SOCKET_TIMEOUT_MS=5000
MINIO_BUCKET=jobclaw
MINIO_BUCKET_PUBLIC_IMAGE=jobclaw-public
MINIO_BUCKET_PRIVATE_MATERIAL=jobclaw-private
MINIO_BUCKET_TEMP=jobclaw-temp
MINIO_BUCKET_EXPORT=jobclaw-export

# JVM and container sizing. Tune them for the real server.
JOBCLAW_JAVA_TOOL_OPTIONS=-Duser.timezone=Asia/Shanghai -XX:MaxRAMPercentage=75.0
ELASTICSEARCH_JAVA_OPTS=-Xms512m -Xmx512m -Duser.timezone=Asia/Shanghai
MYSQL_MEM_LIMIT=1g
REDIS_MEM_LIMIT=256m
KAFKA_MEM_LIMIT=1g
ELASTICSEARCH_MEM_LIMIT=1g
MINIO_MEM_LIMIT=512m
JOBCLAW_API_MEM_LIMIT=1g
JOBCLAW_WEB_MEM_LIMIT=128m
JOBCLAW_GATEWAY_MEM_LIMIT=128m

# Site branding.
JOBCLAW_SITE_WEBSITE_NAME=JobClaw
JOBCLAW_SITE_WEBSITE_LOGO=https://oc.paicoding.com/favicon.icon
JOBCLAW_SITE_LOGIN_QR_IMG=https://cdn.tobebetterjavaer.com/paicoding/paicoding-qrcode.png

# AI provider. Configure real provider keys from the admin LLM provider page when possible.
JOBCLAW_MAIN_MODEL=zhipu
zhipuai-api-key=
openai-api-key=
dashscope-api-key=
spark-api-key=

# Channels are disabled by default for production until credentials are ready.
AGENT_CHANNEL_WECHAT_CLAWBOT_ENABLED=false
AGENT_CHANNEL_DINGDING_ENABLED=false
AGENT_CHANNEL_FEISHU_ENABLED=false
WX_LOGIN_QR_TYPE=SUBSCRIPTION_ACCOUNT
WX_LOGIN_APP_ID=
WX_LOGIN_APP_SECRET=
WX_LOGIN_QR_IMG=
WX_LOGIN_QR_LOGO=
# Must match the callback token configured in the WeChat official account.
WX_SECURITY_CHECK_TOKEN=CHANGE_ME_wechat_callback_token

# Payment is disabled by default.
WX_PAY_ENABLE=false
WX_PAY_APP_ID=
WX_PAY_MERCHANT_ID=
WX_PAY_PRIVATE_KEY=
WX_PAY_MERCHANT_SERIAL_NUMBER=
WX_PAY_API_V3_KEY=
WX_PAY_NOTIFY_URL=
WX_PAY_REFUND_NOTIFY_URL=

# Agent tools. Playwright is preinstalled in the jobclaw image but disabled by default.
AGENT_TOOL_PLAYWRIGHT_ENABLED=false
AGENT_PLAYWRIGHT_HEADLESS=true
